  "formulas": {
    "efg_pct": "(FGM + 0.5 * 3PM) / FGA * 100",
    "tov_pct": "TO / ((FGA - OREB) + TO + (0.475 * FTA)) * 100",
    "oreb_pct": "OREB / (OREB + Opp DREB) * 100",
    "ft_rate": "(FTA per game / FGA per game) * 100",
    "ts_pct": "PTS / (2 * (FGA + 0.475 * FTA)) * 100",
    "dreb_pct": "100 * DREB / ((MIN / team_min / 100) * (team_dreb + opp_oreb))",
    "usage_pct": "TotPoss / ((MIN / team_min / 100) * team_poss)",
    "shot_pct": "100 * FGA / ((MIN / team_min / 100) * team_fga)",
    "ast_rate": "100 * AST / ((MIN / team_min * team_fgm) - FGM)",
    "to_rate": "100 * TO / (FGA + 0.475*FTA + TO)",
    "blk_pct": "100 * BLK / ((MIN / team_min / 100) * (opp_fga - opp_3pa))",
    "stl_pct": "100 * STL / ((MIN / team_min / 100) * team_poss)",
    "fc_per_40": "PF * 40 / MIN",
    "fd_per_40": "(FTA/1.8 + max(0, opp_pf*0.837 - team_fta/1.8) * (MIN/team_min)) * 40/MIN",
    "ind_ortg": "Dean Oliver: 100 * PProd / TotPoss (BBRef method)",
    "ind_drtg": "Dean Oliver: TmDRtg + 0.2*(100*D_Pts_per_ScPoss*(1-Stop%) - TmDRtg)",
    "possessions": "((FGA - OREB) + TO + (0.475 * FTA)) / GP",
    "ortg": "(PPG / Team Possessions) * 100",
    "drtg": "(PPG Allowed / Team Possessions) * 100",
    "net_rtg": "ORTG - DRTG"
  },
